{
  "name": "@sapphire-cms/tsed",
  "private": false,
  "version": "0.2.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "Bridge project to import TsED from to avoid dependency duplication in the bundle.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "author": "Alexei KLENIN",
  "license": "Apache-2.0",
  "homepage": "https://sapphire-cms.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapphire-cms/sapphire-cms.git",
    "directory": "packages/tsed"
  },
  "bugs": {
    "url": "https://github.com/sapphire-cms/sapphire-cms/issues"
  },
  "dependencies": {
    "@tsed/common": "^8.9.5",
    "@tsed/di": "^8.9.5",
    "@tsed/platform-serverless-http": "^8.18.2"
  },
  "scripts": {
    "build": "rollup -c",
    "clean": "rimraf dist",
    "link": "npm link",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "publish:local": "yalc publish",
    "test": "vitest run"
  }
}
